<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivPropertyImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="#F0F0F0"
            android:contentDescription="Фото объявления"/>

        <TextView
            android:id="@+id/tvPropertyId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Объявление № "
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <!-- Город -->
        <TextView
            android:id="@+id/tvCity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginTop="4dp" />

        <!-- Цена -->
        <TextView
            android:id="@+id/tvPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textColor="#6200EE"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <!-- Комнаты и площадь -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvRooms"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Комнат: " />

            <TextView
                android:id="@+id/tvArea"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Площадь: " />

            <TextView
                android:id="@+id/tvType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:background="#4CAF50"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:text="Продажа" />

        </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRespond"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Откликнуться"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#2196F3"
                app:strokeWidth="1dp"
                android:textColor="#2196F3"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Удалить"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#F44336"
                app:strokeWidth="1dp"
                android:textColor="#F44336"/>
    </LinearLayout>

</androidx.cardview.widget.CardView>